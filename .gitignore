# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# 안드로이드 릴리스 서명키 — 절대 커밋 금지.
# 이 키를 잃으면 플레이스토어에 앱 업데이트를 영영 못 올린다(별도 안전 백업 필수).
*.jks
*.keystore
key.properties
android/key.properties

# claude code local settings
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*
